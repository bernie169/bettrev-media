{
  "version": 2,
  "builds": [
    { "src": "api/visit.js", "use": "@vercel/edge" },
    { "src": "api/postback.js", "use": "@vercel/edge" },
    { "src": "public/**", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/visit", "dest": "/api/visit.js" },
    { "src": "/api/postback", "dest": "/api/postback.js" },
    { "src": "/(.*)", "dest": "/public/$1" }
  ]
}
